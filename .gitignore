# ==============================================================================
# CloudAutomationGNN - .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Environment Variables & Secrets
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key

# ------------------------------------------------------------------------------
# 2. Node.js & React (Frontend & Node-Backend)
# ------------------------------------------------------------------------------
node_modules/
npm-debug.log
yarn-error.log
dist/
build/
.npm
coverage/
.eslintcache

# ------------------------------------------------------------------------------
# 3. Python & ML (Python-Backend & ML folder)
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/
ML/models/*.pt
ML/models/*.pth

# ------------------------------------------------------------------------------
# 4. Serverless Framework
# ------------------------------------------------------------------------------
.serverless/

# ------------------------------------------------------------------------------
# 5. Terraform & Infrastructure (infra folder)
# ------------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl
*.tfvars
crash.log

# ------------------------------------------------------------------------------
# 6. OS & IDE
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

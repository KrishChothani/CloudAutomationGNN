{
  "name": "cloud-automation-gnn-node-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Node.js/Express backend for CloudAutomationGNN — REST API, MongoDB, Serverless Framework",
  "main": "src/index.js",
  "scripts": {
    "dev":     "nodemon src/index.js",
    "start":   "node src/index.js",
    "offline": "serverless offline --stage dev",
    "deploy":  "serverless deploy --stage dev"
  },
  "dependencies": {
    "express":          "4.21.0",
    "mongoose":         "8.7.0",
    "jsonwebtoken":     "9.0.2",
    "bcryptjs":         "2.4.3",
    "serverless-http":  "3.2.0",
    "cookie-parser":    "1.4.7",
    "cors":             "2.8.5",
    "dotenv":           "16.4.5",
    "morgan":           "1.10.0",
    "axios":            "1.6.0",
    "@aws-sdk/client-dynamodb": "3.654.0",
    "@aws-sdk/client-sns":      "3.654.0",
    "@aws-sdk/client-sqs":      "3.654.0",
    "@aws-sdk/client-s3":       "3.654.0"
  },
  "devDependencies": {
    "nodemon": "3.1.7",
    "serverless": "3.38.0",
    "serverless-offline": "13.9.0",
    "serverless-dotenv-plugin": "6.0.0"
  }
}
